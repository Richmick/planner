{
	"rdbms": "sqlite3",
	"filename":"./users.sqlite",
	"dbname": "users",
	"client_encoding": "",
	"tables": [],
	"convert":
	{
		"enabled": true,
		"items":
		[
			{
				"table": "users",
				"column": "password",
				"method":
				{
					"before_db_write": "api::hash_password"
				},
				"includes": [
					"\"convert.h\""
				]
			}
		]
	},
	"restful_api_controllers":
	{
		"enabled": true,
		"resource_uri": "/api/*",
		"class_name": "api::restful::*_ctrl",
		"filters": [],
		"db_client":
		{
			"name": "default",
			"is_fast": false
		},
		"directory": "controllers",
		"generate_base_only": true
	}
}
